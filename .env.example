# Company Timezone (REQUIRED)
# IANA timezone identifier for date/time operations
COMPANY_TIMEZONE=Asia/Tokyo

# WorkOS Authentication (REQUIRED)
WORKOS_CLIENT_ID=client_...
WORKOS_API_KEY=sk_...
# Comma-separated list of valid WorkOS issuer URLs for JWT validation
WORKOS_ISSUERS=https://api.workos.com/sso/jwt/issuer_...
# Optional: Custom namespace for WorkOS claims (default: https://api.workos.com/claims/user)
# WORKOS_NAMESPACE=https://api.workos.com/claims/user

# Auth Configuration
# Where WorkOS redirects after authentication
AUTH_REDIRECT_URL=http://localhost:8080/api/v1/auth/callback
# OAuth2 state token secret - REQUIRED for security
# Generate with: openssl rand -base64 32
AUTH_STATE_SECRET=...
# Optional: Cookie domain (default: localhost)
AUTH_DOMAIN=localhost
# Optional: Frontend base URL for redirects (default: http://localhost:5173)
AUTH_BASE_URL=http://localhost:5173
# Optional: CORS allowed origins (default: http://localhost:5173)
AUTH_ALLOWED_ORIGINS=http://localhost:5173

# Database - Option 1: Full connection string (takes precedence)
# DATABASE_URL=postgresql://user:pass@host:port/db?sslmode=disable

# Database - Option 2: Individual variables
DB_HOST=localhost
DB_PORT=5432
DB_USER=boilerplate
DB_PASSWORD=boilerplate
DB_NAME=boilerplate
DB_SSLMODE=disable

# Optional DB pool tuning (all have defaults)
# DB_MAX_CONNS=10
# DB_MIN_CONNS=0
# DB_MAX_CONN_LIFETIME=30m
# DB_CONN_TIMEOUT=5s
